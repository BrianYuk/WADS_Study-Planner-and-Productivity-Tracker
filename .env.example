# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=your-super-secret-app-key-change-this

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/studyplanner_db

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars-change-this
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Redis (optional, for sessions/rate limiting)
REDIS_URL=redis://localhost:6379
